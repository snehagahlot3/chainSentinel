generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model ApiKey {
  id            String   @id @default(cuid())
  organization  Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  name          String
  key           String   @unique
  permissions   String   @default("[]")  // JSON array
  isActive      Boolean  @default(true)
  lastUsedAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model AutomationRule {
  id            String   @id @default(cuid())
  organization  Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  name          String
  description   String?
  triggerType   TriggerType
  triggerConfig Json     // JSON config for trigger conditions
  isActive      Boolean  @default(true)
  priority      Int      @default(0)
  tasks         AutomationTask[]
  executions    RuleExecution[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

enum TriggerType {
  INVENTORY_BELOW_THRESHOLD
  INVENTORY_ZERO
  INVENTORY_RESTOCK
  SALE_COMPLETED
  LARGE_ORDER
  MANUAL
}

model AutomationTask {
  id            String   @id @default(cuid())
  automationRule AutomationRule @relation(fields: [ruleId], references: [id])
  ruleId        String
  taskType      TaskType
  taskConfig    Json     // JSON config for task (email, api_call, etc.)
  order         Int      @default(0)
  isActive      Boolean  @default(true)
  executions    TaskExecution[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

enum TaskType {
  EMAIL
  API_CALL
  WEBHOOK
  CREATE_ORDER
  SMS
}

model RuleExecution {
  id            String   @id @default(cuid())
  automationRule AutomationRule @relation(fields: [ruleId], references: [id])
  ruleId        String
  triggerData   Json     // What triggered the rule
  status        ExecutionStatus @default(PENDING)
  errorMessage  String?
  startedAt     DateTime @default(now())
  completedAt   DateTime?
  taskExecutions TaskExecution[]
}

enum ExecutionStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

model TaskExecution {
  id              String   @id @default(cuid())
  automationTask  AutomationTask @relation(fields: [taskId], references: [id])
  taskId          String
  ruleExecution   RuleExecution @relation(fields: [executionId], references: [id])
  executionId     String
  status          ExecutionStatus @default(PENDING)
  result          String?   // Response from external system
  errorMessage    String?
  retryCount      Int      @default(0)
  startedAt       DateTime @default(now())
  completedAt     DateTime?
}

model Sale {
  id              String   @id @default(cuid())
  organization    Organization @relation(fields: [organizationId], references: [id])
  organizationId  String
  productSku      String
  product         Product? @relation(fields: [productId], references: [id])
  productId       String?
  quantity        Int
  customerEmail   String?
  orderId         String?
  amount          Float?
  metadata        String?  // JSON string
  source          String   @default("api")  // 'api', 'webhook', 'manual'
  createdAt       DateTime @default(now())
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  password      String
  name          String
  role          Role           @default(DISTRIBUTOR)
  organization  Organization?
  products      Product[]      @relation("UserProducts")
  supplierProducts Product[]    @relation("SupplierProducts")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

enum Role {
  ADMIN
  DISTRIBUTOR
  SUPPLIER
}

model Organization {
  id            String          @id @default(cuid())
  name          String
  type          OrganizationType
  userId        String          @unique
  user          User            @relation(fields: [userId], references: [id])
  integrations  Integration[]
  inventories   Inventory[]
  products      Product[]
  alerts        Alert[]
  autoOrderRules AutoOrderRule[]
  orders        Order[]
  apiKeys       ApiKey[]
  automationRules AutomationRule[]
  sales         Sale[]
  predictions   Prediction[]
  salesAnalytics SalesAnalytics[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

enum OrganizationType {
  DISTRIBUTOR
  SUPPLIER
}

model Integration {
  id            String          @id @default(cuid())
  organization  Organization    @relation(fields: [organizationId], references: [id])
  organizationId String
  name          String
  endpointUrl   String
  eventTypes    String         // JSON array stored as string
  isActive      Boolean         @default(true)
  secretKey     String
  webhookEvents WebhookEvent[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model WebhookEvent {
  id            String          @id @default(cuid())
  integration   Integration     @relation(fields: [integrationId], references: [id])
  integrationId String
  eventType     String
  payload       Json
  status        EventStatus     @default(PENDING)
  deliveredAt   DateTime?
  retryCount    Int             @default(0)
  createdAt     DateTime        @default(now())
}

enum EventStatus {
  PENDING
  DELIVERED
  FAILED
}

model Product {
  id            String          @id @default(cuid())
  organization  Organization    @relation(fields: [organizationId], references: [id])
  organizationId String
  name          String
  sku           String
  description   String?
  price         Float
  supplier      User?           @relation("SupplierProducts", fields: [supplierId], references: [id])
  supplierId    String?
  user          User?           @relation("UserProducts", fields: [userId], references: [id])
  userId        String?
  inventories   Inventory[]
  alerts        Alert[]
  autoOrderRules AutoOrderRule[]
  orderItems    OrderItem[]
  sales         Sale[]
  predictions   Prediction[]
  salesAnalytics SalesAnalytics[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model Inventory {
  id            String          @id @default(cuid())
  organization  Organization    @relation(fields: [organizationId], references: [id])
  organizationId String
  product        Product         @relation(fields: [productId], references: [id])
  productId      String
  quantity       Int             @default(0)
  minThreshold   Int             @default(10)
  autoOrderThreshold Int         @default(5)
  lastSyncedAt   DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@unique([organizationId, productId])
}

model Alert {
  id            String          @id @default(cuid())
  organization  Organization    @relation(fields: [organizationId], references: [id])
  organizationId String
  type          AlertType
  message       String
  product        Product?        @relation(fields: [productId], references: [id])
  productId      String?
  isRead         Boolean         @default(false)
  createdAt     DateTime        @default(now())
}

enum AlertType {
  LOW_STOCK
  AUTO_ORDER_TRIGGERED
  WEBHOOK_FAILED
  ORDER_RECEIVED
}

model AutoOrderRule {
  id                String          @id @default(cuid())
  organization      Organization    @relation(fields: [organizationId], references: [id])
  organizationId    String
  product           Product         @relation(fields: [productId], references: [id])
  productId         String
  thresholdQuantity Int
  quantityToOrder   Int
  supplierId        String
  isActive          Boolean         @default(true)
  lastTriggeredAt   DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
}

model Order {
  id            String          @id @default(cuid())
  organization  Organization    @relation(fields: [organizationId], references: [id])
  organizationId String
  orderNumber   String          @unique
  status        OrderStatus     @default(PENDING)
  totalAmount   Float
  supplierId    String?
  items         OrderItem[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}

model OrderItem {
  id            String          @id @default(cuid())
  order         Order           @relation(fields: [orderId], references: [id])
  orderId       String
  product       Product         @relation(fields: [productId], references: [id])
  productId     String
  quantity      Int
  price         Float
}

model Prediction {
  id                  String       @id @default(cuid())
  organization        Organization  @relation(fields: [organizationId], references: [id])
  organizationId     String
  product            Product       @relation(fields: [productId], references: [id])
  productId         String
  predictedDepletion DateTime?
  riskLevel         RiskLevel
  confidence        Float
  recommendedOrderQty Int?
  daysRemaining   Int?
  modelVersion   String      @default("1.0")
  createdAt     DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@unique([organizationId, productId])
}

enum RiskLevel {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

model SalesAnalytics {
  id              String       @id @default(cuid())
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  product         Product      @relation(fields: [productId], references: [id])
  productId      String
  periodDays     Int
  unitsSold     Int
  avgDailySales Float
  trend        Float
  createdAt    DateTime    @default(now())

  @@unique([organizationId, productId, periodDays])
}